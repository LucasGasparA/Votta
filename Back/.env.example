# ─── Banco de dados ───────────────────────────────────────────
# Railway injeta DATABASE_URL automaticamente quando você adiciona o plugin PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Autenticação ─────────────────────────────────────────────
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria

# ─── URLs ─────────────────────────────────────────────────────
# URL pública do frontend (sem barra no final)
FRONTEND_URL=https://seu-frontend.up.railway.app
# URL pública do backend (usado nos e-mails de reset de senha)
APP_URL=https://seu-backend.up.railway.app

# ─── Google Vertex AI ─────────────────────────────────────────
GCP_PROJECT_ID=seu-projeto-gcp
GCP_LOCATION=us-central1
GCP_MODEL=gemini-1.5-pro
# Cole aqui o conteúdo COMPLETO do JSON da service account (em uma linha ou multi-line)
GCP_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ─── E-mail (reset de senha) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=Votta <seu-email@gmail.com>

# ─── Ambiente ─────────────────────────────────────────────────
NODE_ENV=production
# PORT é injetado automaticamente pelo Railway — não defina aqui
